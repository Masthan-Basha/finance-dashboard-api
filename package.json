{
  "name": "finance-dashboard-api",
  "version": "1.0.0",
  "description": "Finance Data Processing and Access Control Backend",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force && node prisma/seed.js",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/jwt": "^9.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "prisma": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
